# ── Application ──────────────────────────────────────────────────
APP_NAME="BackendForge API"
APP_ENV=development
DEBUG=true
SECRET_KEY=supersecretkey-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ──────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/backendforge
SYNC_DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/backendforge

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Email (SMTP) ──────────────────────────────────────────────────
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your_mailtrap_user
SMTP_PASSWORD=your_mailtrap_password
EMAILS_FROM_EMAIL=noreply@backendforge.dev
EMAILS_FROM_NAME="BackendForge API"

# ── File Storage ──────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10

# ── CORS ─────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Rate Limiting ─────────────────────────────────────────────────
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_API=60/minute

# ── Admin Seed ────────────────────────────────────────────────────
ADMIN_EMAIL=admin@backendforge.dev
ADMIN_PASSWORD=Admin@1234
ADMIN_FULL_NAME="System Admin"
